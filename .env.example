SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-04

# Dev Dashboard 新应用推荐：Client Credentials Grant
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret

# 旧版 Shopify Admin custom app 才会有这个 token；新版 Dev Dashboard 通常不用填
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_or_token

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-or-secret-key

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# 可选：不填则默认使用 https://你的域名/api/oauth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/google/callback

CRON_SECRET=change-this-to-a-long-random-string
SHOPIFY_SYNC_START_DATE=2026-05-01T00:00:00.000Z
SHOPIFY_SYNC_PAGE_SIZE=50
SHOPIFY_SYNC_MAX_PAGES=4
